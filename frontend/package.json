{
  "name": "super-lig-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prepare:assets": "node ./scripts/sync-public-assets.mjs",
    "finalize:build": "node ./scripts/sync-dist-assets.mjs",
    "build": "npm run prepare:assets && rescript build -with-deps && vite build && npm run finalize:build",
    "preview": "vite preview",
    "res:build": "rescript build -with-deps",
    "res:watch": "rescript build -w -with-deps",
    "test": "rescript build -with-deps && node --test test/*.test.mjs",
    "verify:deploy": "npm run test && npm run build"
  },
  "dependencies": {
    "@rescript/core": "^1.6.0",
    "@rescript/react": "^0.13.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "rescript": "^11.1.4",
    "vite": "^5.4.1"
  }
}
